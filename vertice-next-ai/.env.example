# Vértice Next AI — variáveis de ambiente
#
# Copie este arquivo para `.env` na raiz do projeto e preencha com as
# credenciais do SEU projeto Firebase (Configurações do projeto > Geral >
# "Seus apps" > SDK do Firebase, no console do Firebase).
#
# Todas as variáveis usadas pelo Vite precisam começar com VITE_.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Branding (opcional — usado apenas em textos da interface)
VITE_APP_NAME="Vértice Next AI"
VITE_PILOT_CLIENT="CuteFood CWB"

# n8n — Webhook do workflow workflows/briefing.json (Webhook -> Validar dados
# -> Salvar no Firestore -> Retornar JSON). Obrigatória para criar briefings
# a partir do front-end. Veja docs/integracoes/n8n.md.
VITE_N8N_WEBHOOK_URL=

# Multi-tenant — empresa padrão usada enquanto não há login/seleção real de
# empresa na interface. Ver docs/arquitetura/CF-070-modelagem-multi-tenant.md.
VITE_DEFAULT_COMPANY_ID=cutefood-cwb

# Evolution API (WhatsApp) — usada por src/services/evolution.ts para enviar
# texto, indicador de digitação, confirmação de leitura e imagens.
# Veja docs/integracoes/evolution.md.
VITE_EVOLUTION_URL=
VITE_EVOLUTION_INSTANCE=
VITE_EVOLUTION_API_KEY=
